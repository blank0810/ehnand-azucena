FROM node:20-alpine

WORKDIR /app

# pnpm is the project's package manager (via corepack)
RUN corepack enable

# Install dependencies only when the lockfile changes
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Copy source code (overridden by bind mount in dev)
COPY . .

EXPOSE 3000

CMD ["pnpm", "dev"]
