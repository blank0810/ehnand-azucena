# Absolute base URL of the deployed site (no trailing slash).
# Used server-side for canonical/OG metadata, JSON-LD, robots.txt and sitemap.xml.
# Set this in your Vercel project settings (Production = the live domain).
# If unset, the app falls back to https://ehnand.com (see lib/site.ts).
NEXT_APP_URL=https://ehnand.com

# Google Search Console site-verification token (HTML tag method).
# Get it from https://search.google.com/search-console -> Add property ->
# ehnand.com -> "HTML tag" verification -> copy only the `content` value.
# If unset, no google-site-verification meta tag is rendered (see app/layout.tsx).
GOOGLE_SITE_VERIFICATION=
